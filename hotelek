/*Kérdezzük le az összes hotel nevét, a hozzátartozók szobák nevét, és azok foglalásait.*/

select h.name, r.room_name, rr.start_date, rr.end_date from hotel h
inner join room r on h.id = r.hotel_id
inner join room_reservation rr on  r.id = rr.room_id;

select h.name, r.room_name, rr.start_date, rr.end_date from hotel h
inner join room r on h.id = r.hotel_id
left join room_reservation rr on  r.id = rr.room_id

/*Kérdezzük le azoknak a felhasználóknak a vezeték és keresztnevét, akikhez NEM tartozik foglalás.*/

select a.firstname, a.lastname, b.id from account a
left join booking b on a.user_id = b.guest
where b.id is null;

/*Kérdezzük le azoknak a hoteleknek a nevét, amelyekhez legalább 5 hotel_feature tartozik*/

select h.name, count(*) as featureCount from hotel h
inner join hotel_features on h.id = hotel_id
group by h.id
having featureCount >= 5
/*Jelenítsük meg minden hotel nevét és a hozzájuk tartozó feature számát a hotel neve szerint csoportosítva. Azok a hotelek is jelenjenek meg, amelyekhez nincs feature rendelve!*/

select h.name, 
case when min(hf.hotel_features) is null then 0
    else count(*) 
end as featureCount from hotel h
left join hotel_features hf on h.id = hf.hotel_id
group by h.name

select h.name, count(hf.hotel_id) as featureCount from hotel h
left join hotel_features hf on h.id = hf.hotel_id
group by h.name
